#!/usr/bin/env bash
# Compound Learning — Extract learnings from progress.txt
# Basic version: reads progress.txt, extracts learnings, writes to docs/solutions/.
# A future upgrade replaces this with the full 5-agent, 14-category system.
#
# Usage: ./compound-learning.sh

source "$(dirname "$0")/lib.sh"

cd "$PROJECT_ROOT"

PROGRESS_FILE="$OUTPUT_DIR/progress.txt"
# v2.1.5 BL-335: LaunchPad never produces `prd.json` — it produces
# `docs/architecture/PRD.md` via /lp-define. The legacy CE-port assumed
# `prd.json` (the CE plugin's artifact). Consume the canonical sources
# the LaunchPad pipeline actually ships: PRD.md + scaffold-receipt.json.
# Hand-authored `prd.json` files (CE-format legacy) are still honored as
# an optional override when present at $OUTPUT_DIR/prd.json.
PRD_JSON_FILE="$OUTPUT_DIR/prd.json"
PRD_MD_FILE="$PROJECT_ROOT/docs/architecture/PRD.md"
RECEIPT_FILE="$PROJECT_ROOT/.launchpad/scaffold-receipt.json"
TEMPLATE_FILE="$PROJECT_ROOT/docs/solutions/compound-product/_template.md"

if [ ! -f "$PROGRESS_FILE" ]; then
  log "No progress.txt found. Nothing to extract."
  exit 0
fi

# Derive feature slug. Precedence: (1) hand-authored prd.json's branchName,
# (2) current git branch.
if [ -f "$PRD_JSON_FILE" ]; then
  BRANCH_NAME=$(jq -r '.branchName // empty' "$PRD_JSON_FILE" 2>/dev/null || echo "")
else
  BRANCH_NAME=""
fi
if [ -z "$BRANCH_NAME" ]; then
  BRANCH_NAME=$(git branch --show-current 2>/dev/null || echo "")
fi

FEATURE_SLUG=$(echo "$BRANCH_NAME" | sed "s|^${BRANCH_PREFIX}||" | sed 's|^compound/||')
if [ -z "$FEATURE_SLUG" ]; then
  FEATURE_SLUG="unknown-feature"
fi

LEARNINGS_DIR="$PROJECT_ROOT/docs/solutions/compound-product/$FEATURE_SLUG"
LEARNINGS_FILE="$LEARNINGS_DIR/${FEATURE_SLUG}-$(date +%Y-%m-%d).md"

# Count task stats. Precedence: hand-authored prd.json (CE-format legacy);
# otherwise derive zero counts and rely on the progress log for context.
TASKS_TOTAL=0
TASKS_COMPLETED=0
ITERATION_COUNT=0

if [ -f "$PRD_JSON_FILE" ]; then
  TASKS_TOTAL=$(jq '.tasks | length' "$PRD_JSON_FILE" 2>/dev/null || echo 0)
  TASKS_COMPLETED=$(jq '[.tasks[] | select(.passes == true)] | length' "$PRD_JSON_FILE" 2>/dev/null || echo 0)
fi
ITERATION_COUNT=$(grep -c "^## " "$PROGRESS_FILE" 2>/dev/null || echo 0)

# Get PR URL if available
PR_URL=$(gh pr view --json url -q '.url' 2>/dev/null || echo "N/A")

if [ -f "$TEMPLATE_FILE" ]; then
  mkdir -p "$LEARNINGS_DIR"

  # v2.1.5 BL-335 + round-3 review fix B9 (Codex P2 + simplicity-reviewer
  # P3): include PRD.md + scaffold-receipt.json when available so the
  # extractor has product/stack context for the learnings. Prior shape
  # declared `PRD_MD_FILE` + `RECEIPT_FILE` as load-bearing but never
  # referenced them in the prompt — they were dead-code masquerading as
  # canonical-LaunchPad-artifact integration.
  PRD_CONTEXT=""
  if [ -f "$PRD_MD_FILE" ]; then
    PRD_CONTEXT="Product context (docs/architecture/PRD.md):
$(cat "$PRD_MD_FILE")

"
  fi
  RECEIPT_CONTEXT=""
  if [ -f "$RECEIPT_FILE" ]; then
    RECEIPT_CONTEXT="Stack context (.launchpad/scaffold-receipt.json):
$(cat "$RECEIPT_FILE")

"
  fi

  EXTRACT_PROMPT="Read this progress log and extract a structured learnings document.

${PRD_CONTEXT}${RECEIPT_CONTEXT}Progress log:
$(cat "$PROGRESS_FILE")

Template to follow (fill in the YAML frontmatter and sections):
$(cat "$TEMPLATE_FILE")

Fill in these values:
- title: ${FEATURE_SLUG}
- feature: ${FEATURE_SLUG}
- date: $(date +%Y-%m-%d)
- branch: ${BRANCH_NAME}
- tasks_total: ${TASKS_TOTAL}
- tasks_completed: ${TASKS_COMPLETED}
- iterations_used: ${ITERATION_COUNT}
- max_iterations: ${MAX_ITERATIONS}
- pr_url: ${PR_URL}

Extract ALL learnings, patterns, gotchas, and file changes from the progress log.
Use the product + stack context above to ground learnings in the project's
actual surface (specific files, frameworks, stack patterns) rather than
abstract advice.
Output ONLY the filled-in markdown document, nothing else."

  LEARNINGS_CONTENT=$(echo "$EXTRACT_PROMPT" | ai_run 2>&1)

  if [ -n "$LEARNINGS_CONTENT" ]; then
    echo "$LEARNINGS_CONTENT" > "$LEARNINGS_FILE"
    log "Learnings saved to: $LEARNINGS_FILE"
  else
    log "WARNING: Failed to extract learnings. Review progress.txt manually."
  fi
else
  log "WARNING: No template found at $TEMPLATE_FILE. Skipping structured extraction."
  mkdir -p "$LEARNINGS_DIR"
  # Fallback: just copy progress.txt as raw learnings
  cp "$PROGRESS_FILE" "$LEARNINGS_FILE"
  log "Raw progress copied to: $LEARNINGS_FILE"
fi

log "Review your learnings: $LEARNINGS_FILE"
log "Promote patterns to: docs/solutions/compound-product/patterns/promoted-patterns.md"
