name: Bug Report
description: Report a defect in {{ identity.project_name }}.
title: "[Bug]: "
labels: ["bug", "needs-triage"]
body:
  - type: markdown
    attributes:
      value: |
        Thanks for taking the time to report a bug. Please fill in the fields
        below; complete information speeds up triage and makes a fix more likely.

  - type: input
    id: version
    attributes:
      label: Project version
      description: Commit SHA, release tag, or version string from your install.
      placeholder: "v1.2.3 / abc123"
    validations:
      required: true

  - type: input
    id: os
    attributes:
      label: Operating system
      placeholder: "macOS 14.5 / Ubuntu 22.04 / Windows 11 + WSL2"
    validations:
      required: true

  - type: textarea
    id: what-happened
    attributes:
      label: What happened
      description: A clear description of the bug.
    validations:
      required: true

  - type: textarea
    id: expected
    attributes:
      label: What you expected to happen
    validations:
      required: true

  - type: textarea
    id: reproduce
    attributes:
      label: Steps to reproduce
      description: Minimal sequence of commands or actions that triggers the bug.
      placeholder: |
        1. Run ...
        2. Observe ...
    validations:
      required: true

  - type: textarea
    id: logs
    attributes:
      label: Relevant output or logs
      description: Paste error messages, command output, or audit-log lines. Redact secrets.
      render: shell
    validations:
      required: false

  - type: textarea
    id: extra-context
    attributes:
      label: Additional context
    validations:
      required: false
