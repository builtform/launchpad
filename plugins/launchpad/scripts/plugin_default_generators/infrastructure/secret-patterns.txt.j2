# Secret-scan patterns sourced by lefthook.yml's secret-scan hook.
# One regex per line; lines starting with `#` are comments.
# Project: {{ identity.project_name }}

# AWS
AKIA[0-9A-Z]{16}
ASIA[0-9A-Z]{16}

# GitHub
gh[pousr]_[A-Za-z0-9]{36,255}

# Slack
xox[abprs]-[A-Za-z0-9-]{10,48}

# Generic high-entropy tokens (40-char hex)
[a-f0-9]{40,}

# Stripe
sk_live_[A-Za-z0-9]{24,99}
rk_live_[A-Za-z0-9]{24,99}

# Anthropic
sk-ant-[A-Za-z0-9-]{32,}

# Generic passwords / tokens in env-style assignments
(?i)(password|passwd|secret|token|api[_-]?key)\s*[:=]\s*['"][^'"\s]{12,}['"]
